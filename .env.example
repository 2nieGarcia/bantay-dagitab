# Bantay-Dagitab — Centralized environment template
#
# Single source of truth for all services. Copy to .env at the repo root
# and fill in. Both the Django backend and the ML service load THIS file.
#
#   cp .env.example .env
#
# Per-service .env files (backend/.env, ml/.env) are no longer used.

# =============================================================================
# Django backend
# =============================================================================

# Django secret key. Generate a fresh one for each environment:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Set to True only on Render. Locally, leave as False so DEBUG is True.
RENDER=False

# =============================================================================
# Shared — Supabase database (Django + ML both connect here)
# =============================================================================

# Format: postgresql://user:pass@host:port/dbname
# For Supabase, use the Session Pooler URL (IPv4-reachable):
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# =============================================================================
# Shared — service-account token (paper §VI.F.2)
# =============================================================================
# Used by the IoT firmware/simulator and the ML inference worker to
# authenticate against /api/iot/readings/ingest/ and /api/analytics/ingest/
# via the X-Service-Token header. Generate any high-entropy string:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SERVICE_ACCOUNT_TOKEN=

# =============================================================================
# Django chatbot — external LLM provider (OpenAI-compatible)
# =============================================================================
# Paper §IV.B / §VII.A.4: the Django chatbot view calls an external LLM API
# directly (Groq cloud or Ollama local).
#
# --- Groq (cloud, free tier) ---
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=gsk_your_groq_key_here
#   LLM_MODEL=llama-3.3-70b-versatile
#
# --- Ollama (local; from inside Docker use host.docker.internal) ---
#   LLM_BASE_URL=http://host.docker.internal:11434/v1
#   LLM_API_KEY=ollama
#   LLM_MODEL=llama3.1
#
# If any of LLM_BASE_URL / LLM_API_KEY / LLM_MODEL is blank, /api/chat/ask/
# returns a canned fallback string instead of erroring.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30

# =============================================================================
# ML service
# =============================================================================

# Where the ML inference worker pushes Contract C alerts.
# - Host mode (running the worker from your venv on the host):
#       BACKEND_API_URL=http://localhost:8000/api
# - Docker mode (the docker-compose `ml` service): the compose file
#       overrides this to http://backend:8000/api at container start.
BACKEND_API_URL=http://localhost:8000/api

# ML debug flag (sets uvicorn log level inside ml/app/main.py).
DEBUG=True

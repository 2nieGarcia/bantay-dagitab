# FastAPI ML service environment template.
# Copy to ml/.env and fill in.
#
# This service hosts (future) anomaly detection and forecasting per
# paper §IV.C. It does NOT host the chatbot — Django calls the external
# LLM API directly. LLM config lives in backend/.env, not here.

DEBUG=True

# Callback URL the ML service uses to push results back into the Django
# backend (e.g., POST anomaly alerts). Overridden in docker-compose.
BACKEND_API_URL=http://backend:8000/api

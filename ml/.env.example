# ML service — deployment env template.
#
# This file lists the env vars the ML service needs when deployed
# standalone (Render, Fly, Heroku, etc.). On those platforms you set
# these values through the platform's UI, not through a file.
#
# For LOCAL DEVELOPMENT, do NOT create ml/.env. The repo uses a
# centralized <repo_root>/.env that docker-compose injects into both
# services. See <repo_root>/.env.example for the local template.

# --- Logging ---
DEBUG=True

# --- Database (Supabase — shared with Django backend) ---
# Same Supabase database the Django backend uses. The ML service reads
# from Django's iot_monitoring_iotreading and owns its own observability
# tables (ml_predictions_log, ml_worker_state — see
# ml/ml_observability_tables.sql).
DATABASE_URL=

# --- Django callback (Contract C, paper §VI.F.2) ---
# When the inference worker triggers a sustained-3 anomaly, it POSTs the
# Contract C payload to {BACKEND_API_URL}/analytics/ingest/ with the
# X-Service-Token header. Must match the backend's SERVICE_ACCOUNT_TOKEN.
BACKEND_API_URL=https://your-backend.example.com/api
SERVICE_ACCOUNT_TOKEN=

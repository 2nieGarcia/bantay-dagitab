# Django backend — deployment env template.
#
# This file lists the env vars the backend service needs when deployed
# standalone (Render, Fly, Heroku, etc.). On those platforms you set
# these values through the platform's UI, not through a file.
#
# For LOCAL DEVELOPMENT, do NOT create backend/.env. The repo uses a
# centralized <repo_root>/.env that docker-compose injects into both
# services. See <repo_root>/.env.example for the local template.

# --- Django ---
SECRET_KEY=
RENDER=True

# --- Database (Supabase) ---
# postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# --- Service-account token (paper §VI.F.2) ---
# Used by the IoT firmware/simulator AND the ML inference worker to
# authenticate against /api/iot/readings/ingest/ and /api/analytics/ingest/
# via the X-Service-Token header. Must match the value the ML service
# sees. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SERVICE_ACCOUNT_TOKEN=

# --- Chatbot LLM provider (OpenAI-compatible) ---
# Paper §IV.B / §VII.A.4. If any of these is blank, /api/chat/ask/
# returns the canned fallback instead of erroring.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30

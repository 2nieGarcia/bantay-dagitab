# Example environment file
# Copy this file to backend/.env and fill in your own values.

# --- Django ---
SECRET_KEY=
RENDER=False

# --- Database ---
# Format: postgres://user:pass@host:port/dbname
# For Supabase, use the Session Pooler URL (IPv4-reachable):
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# --- Service Account token (paper §VI.F.2) ---
# Used by the IoT firmware/simulator and the ML service to authenticate against
# /api/iot/readings/ingest/ and /api/analytics/ingest/ via the X-Service-Token
# header. Pick any high-entropy string; rotate per release.
SERVICE_ACCOUNT_TOKEN=

# --- Chatbot LLM provider (OpenAI-compatible) ---
# Paper §IV.B / §VII.A.4: the Django chatbot view calls an external LLM API
# directly (Groq cloud or Ollama local).
#
# --- Groq (cloud, free tier) ---
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=gsk_your_groq_key_here
#   LLM_MODEL=llama-3.3-70b-versatile
#
# --- Ollama (local; from inside Docker use host.docker.internal) ---
#   LLM_BASE_URL=http://host.docker.internal:11434/v1
#   LLM_API_KEY=ollama
#   LLM_MODEL=llama3.1
#
# If any of LLM_BASE_URL / LLM_API_KEY / LLM_MODEL is blank, /api/chat/ask/
# returns a canned fallback string instead of erroring.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
